# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only: DALL-E uploads to Storage (optional but recommended for AI images)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional integrations (features degrade gracefully when unset)
PEXELS_API_KEY=
OPENAI_API_KEY=
SPOONACULAR_API_KEY=
YOUTUBE_API_KEY=

# Canonical site URL for metadata (optional; defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
